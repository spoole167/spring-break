<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.example</groupId>
        <artifactId>spring-boot-migration-tests</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>spring-session-property-renames</artifactId>
    <name>Tier 3 — Spring Session Property Prefixes Silently Renamed</name>
    <description>Boot 4.0 renames spring.session.redis.* properties to spring.session.data.redis.* (and the equivalent for MongoDB). The legacy prefix is silently ignored — sessions persist with default namespace/collection names rather than the configured ones.</description>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.session</groupId>
            <artifactId>spring-session-data-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <profiles>
        <!--
            Boot 4 split spring-boot-autoconfigure into per-concern modules.
            The Session-Redis auto-config moved to spring-boot-session-data-redis,
            which is NOT pulled in by spring-boot-starter-data-redis. Add it
            explicitly when running on 4.0.7 so the auto-config fires and we can
            observe the property-rename behaviour. The artifact does not exist
            on Boot 3.5 (its auto-config was inside spring-boot-autoconfigure).
        -->
        <profile>
            <id>boot4-session-modules</id>
            <activation>
                <property>
                    <name>spring-boot.version</name>
                    <value>4.0.7</value>
                </property>
            </activation>
            <dependencies>
                <dependency>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-session-data-redis</artifactId>
                </dependency>
            </dependencies>
        </profile>
    </profiles>

</project>
